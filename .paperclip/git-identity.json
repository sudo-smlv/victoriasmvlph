{
  "$schema": "https://paperclip.ai/schemas/git-identity/v1.json",
  "description": "Canonical git identity for each Paperclip agent in ClawTeam Engineering. Used by scripts/paperclip-set-git-identity.sh (workspace bootstrap) and scripts/check-pr-author.sh (CI lint) to enforce chain-of-custody on commits. Mirrors the table in docs/git-identity.md.",
  "fallback": {
    "name": "Paperclip Agent",
